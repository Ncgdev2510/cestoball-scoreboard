{
  "name": "scoreboard-pro",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "description": "Panel y marcador (Electron + Vite + React)",
  "author": "",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:electron": "node scripts/build-electron.mjs",
    "build:electron:watch": "node scripts/build-electron.mjs --watch",
    "dev:electron": "npm run build:electron && concurrently -k \"vite\" \"npm run build:electron:watch\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "pack": "npm run build && npm run build:electron && electron-builder",
    "pack:dir": "npm run build && npm run build:electron && electron-builder --dir",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "license:gen-keys": "node scripts/gen-keypair.mjs",
    "license:sign": "node scripts/sign-license.mjs",
    "license:hwid": "node scripts/print-hwid.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "lucide-react": "^0.344.0",
    "node-machine-id": "^1.1.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.scoreboard.pro",
    "productName": "Scoreboard Pro",
    "copyright": "Copyright © ${author}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
